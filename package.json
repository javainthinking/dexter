{
  "name": "dexter-ts",
  "version": "2026.5.11",
  "description": "Dexter - AI agent for deep financial research.",
  "type": "module",
  "main": "src/index.tsx",
  "bin": {
    "dexter-ts": "./src/index.tsx"
  },
  "workspaces": [
    "apps/*"
  ],
  "exports": {
    "./ports": "./src/ports/index.ts",
    "./adapters/*": "./src/adapters/*.ts",
    "./entrypoints/web/compose": "./src/entrypoints/web/compose.ts",
    "./agent": "./src/agent/index.ts",
    "./controllers": "./src/controllers/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "gateway": "tsx src/gateway/index.ts run",
    "gateway:login": "tsx src/gateway/index.ts login",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/s3-request-presigner": "^3.1050.0",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/exa": "^1.0.1",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@langchain/tavily": "^1.2.0",
    "@mariozechner/pi-tui": "^0.52.12",
    "@mozilla/readability": "^0.6.0",
    "@vercel/blob": "^2.3.3",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "croner": "^9.1.0",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "exa-js": "^2.10.1",
    "gray-matter": "^4.0.3",
    "langsmith": "^0.4.12",
    "linkedom": "^0.18.12",
    "playwright": "^1.58.2",
    "postgres": "^3.4.9",
    "qrcode-terminal": "^0.12.0",
    "valyu-js": "^2.7.16",
    "yahoo-finance2": "^3.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/jest": "^29.5.14",
    "@types/qrcode-terminal": "^0.12.2",
    "babel-jest": "^30.3.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
